---
import { getAgent } from "../../js/backend.mjs";
import Layout from "../../layouts/Layout.astro";

const { id } = Astro.params;
// utilisation d'un type any pour éviter les erreurs de propriété
const agent: any = await getAgent(id);
---

<Layout titre={agent.nom}>
    <h2>{agent.prenom}</h2>
    <ul>
        <li>{agent.email}</li>
        Voici des informatiosn plus poussé sur notre agent.
    </ul>
</Layout>
